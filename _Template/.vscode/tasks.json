{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Start Claude",
            "type": "process",
            "command": "wt",
            "args": [],
            "windows": {
                "command": "wt",
                "args": [
                    "new-tab",
                    "--title",
                    "${workspaceFolderBasename}",
                    "--startingDirectory",
                    "${workspaceFolder}",
                    "--suppressApplicationTitle",
                    "--",
                    "powershell",
                    "-NoExit",
                    "-ExecutionPolicy",
                    "Bypass",
                    "-File",
                    "${env:USERPROFILE}/.claude/start-claude.ps1"
                ]
            },
            "osx": {
                "command": "osascript",
                "args": [
                    "-e",
                    "tell application \"Terminal\" to do script \"cd '${workspaceFolder}' && claude\""
                ]
            },
            "presentation": {
                "reveal": "silent"
            },
            "runOptions": {
                "runOn": "folderOpen"
            }
        }
    ]
}
